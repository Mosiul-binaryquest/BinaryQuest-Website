    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: #050B14; color: #eef5ff; overflow-x: hidden; }
        nav { display: flex; justify-content: space-between; align-items: center; padding: 20px 50px; background: rgba(5, 11, 20, 0.95); backdrop-filter: blur(10px); position: sticky; top: 0; z-index: 100; border-bottom: 1px solid rgba(0, 255, 170, 0.1); }
        .logo { font-size: 28px; font-weight: 800; background: linear-gradient(135deg, #FFFFFF 0%, #00FFAA 100%); -webkit-background-clip: text; background-clip: text; color: transparent; }
        .nav-links { display: flex; gap: 40px; list-style: none; }
        .nav-links a { text-decoration: none; color: #b0c4de; font-weight: 500; transition: 0.3s; }
        .nav-links a:hover, .nav-links a.active { color: #00FFAA; }
        .dropdown { position: relative; display: inline-block; }
        .dropdown-content { display: none; position: absolute; background: rgba(10, 20, 30, 0.95); backdrop-filter: blur(10px); min-width: 220px; border-radius: 12px; border: 1px solid rgba(0, 255, 170, 0.2); z-index: 1; top: 100%; left: 0; }
        .dropdown-content a { color: #b0c4de; padding: 12px 20px; display: block; font-size: 14px; }
        .dropdown-content a:hover { background: rgba(0, 255, 170, 0.1); color: #00FFAA; }
        .dropdown:hover .dropdown-content { display: block; }
        .btn-outline { border: 1px solid #00FFAA; background: transparent; padding: 10px 24px; border-radius: 40px; color: #00FFAA; font-weight: 600; cursor: pointer; transition: 0.3s; }
        .btn-outline:hover { background: #00FFAA; color: #050B14; box-shadow: 0 0 15px #00FFAA; }
        .btn-solid { background: #00FFAA; border: none; padding: 14px 32px; border-radius: 40px; font-weight: 700; color: #050B14; cursor: pointer; transition: 0.3s; font-size: 16px; }
        .btn-solid:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(0, 255, 170, 0.3); }
        .container { max-width: 1400px; margin: 0 auto; padding: 0 30px; }
        .hero { padding: 80px 0 60px; background: radial-gradient(circle at 30% 50%, rgba(0, 255, 170, 0.08), transparent); }
        .hero-content { display: flex; align-items: center; gap: 50px; flex-wrap: wrap; }
        .hero-text { flex: 1; }
        .hero-text h1 { font-size: 52px; font-weight: 800; margin-bottom: 20px; line-height: 1.2; }
        .gradient-text { background: linear-gradient(135deg, #00FFAA, #00CC88); -webkit-background-clip: text; background-clip: text; color: transparent; }
        .hero-text p { font-size: 18px; color: #b0c4de; margin-bottom: 30px; line-height: 1.6; }
        .hero-stats { display: flex; gap: 40px; margin-top: 30px; flex-wrap: wrap; }
        .stat-item h3 { font-size: 32px; color: #00FFAA; }
        .hero-image { flex: 1; background: linear-gradient(135deg, rgba(0, 255, 170, 0.1), rgba(0, 100, 50, 0.2)); border-radius: 30px; padding: 40px; text-align: center; border: 1px solid rgba(0, 255, 170, 0.2); }
        .hero-image i { font-size: 80px; color: #00FFAA; opacity: 0.8; }
        .section-title { text-align: center; font-size: 36px; font-weight: 700; margin: 60px 0 20px; }
        .section-subtitle { text-align: center; color: #b0c4de; margin-bottom: 50px; font-size: 18px; max-width: 700px; margin-left: auto; margin-right: auto; }
        .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; margin: 60px 0; }
        .stat-card { background: rgba(10, 20, 30, 0.6); backdrop-filter: blur(10px); border-radius: 20px; padding: 30px; text-align: center; border: 1px solid rgba(0, 255, 170, 0.1); transition: 0.3s; }
        .stat-card:hover { transform: translateY(-5px); border-color: #00FFAA; }
        .stat-number { font-size: 42px; font-weight: 800; color: #00FFAA; }
        .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px; margin: 50px 0; }
        .feature-card { background: rgba(10, 20, 30, 0.6); backdrop-filter: blur(10px); border-radius: 20px; padding: 30px; border: 1px solid rgba(0, 255, 170, 0.1); transition: 0.3s; }
        .feature-card:hover { transform: translateY(-5px); border-color: #00FFAA; background: rgba(0, 255, 170, 0.05); }
        .feature-icon { width: 60px; height: 60px; background: rgba(0, 255, 170, 0.1); border-radius: 15px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; font-size: 28px; color: #00FFAA; }
        .feature-card h3 { font-size: 20px; margin-bottom: 12px; }
        .feature-card p { color: #b0c4de; line-height: 1.5; font-size: 14px; }
        .companies-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 30px; margin: 50px 0; }
        .company-card { background: linear-gradient(135deg, #0a1420, #061020); border-radius: 24px; overflow: hidden; border: 1px solid rgba(0, 255, 170, 0.15); transition: 0.3s; }
        .company-card:hover { transform: translateY(-5px); border-color: #00FFAA; }
        .company-header { padding: 25px; background: rgba(0, 255, 170, 0.05); display: flex; align-items: center; gap: 20px; border-bottom: 1px solid rgba(0, 255, 170, 0.1); }
        .company-logo { width: 60px; height: 60px; background: rgba(0, 255, 170, 0.15); border-radius: 15px; display: flex; align-items: center; justify-content: center; font-size: 30px; color: #00FFAA; }
        .company-info h3 { font-size: 22px; margin-bottom: 5px; }
        .company-industry { font-size: 13px; color: #00FFAA; }
        .company-details { padding: 25px; }
        .company-stats { display: flex; gap: 20px; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid rgba(0, 255, 170, 0.1); }
        .company-stat { flex: 1; text-align: center; }
        .company-stat-value { font-size: 22px; font-weight: 700; color: #00FFAA; }
        .company-stat-label { font-size: 11px; color: #b0c4de; }
        .testimonial { background: rgba(0, 255, 170, 0.05); padding: 15px; border-radius: 12px; margin-top: 15px; font-style: italic; font-size: 13px; color: #c0d4e8; border-left: 3px solid #00FFAA; }
        .cta-section { background: linear-gradient(135deg, #0a1420, #061020); border-radius: 30px; padding: 60px; text-align: center; margin: 60px 0; border: 1px solid rgba(0, 255, 170, 0.2); }
        @media (max-width: 768px) {
